# BlueSafe Platform local ports
FRONTEND_PORT=5179

# apps/mobile-frontend
VITE_BE1_URL=http://localhost:3000
VITE_BE2_URL=http://localhost:3100
VITE_WALLET_API_URL=http://localhost:3000
VITE_BLUESAFE_AUTH_TOKEN=
CORS_ORIGIN=http://localhost:5179,http://127.0.0.1:5179

# services/be1-xrpl
# Root npm scripts set BE1 PORT=3000.
XRPL_NETWORK_URL=wss://s.altnet.rippletest.net:51233
XRPL_EXPLORER_URL=https://testnet.xrpl.org
XRPL_FAUCET_URL=https://faucet.altnet.rippletest.net/accounts
# Required for real XRPL escrow creation through POST /contracts.
# Leave empty only when testing wallet connection / UI fallback flows.
XRPL_OPERATOR_SEED=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesafe_dev
REDIS_HOST=localhost
REDIS_PORT=6379
ENCRYPTION_MASTER_KEY=

# services/be2-ops
# Root npm scripts set BE2 PORT=3100.
IPFS_MODE=mock
BLUESAFE_AUTH=0
XRPL_WSS_URL=
