# =====================================================
# BlueSafe Backend 1 — 환경변수 예시
# 로컬 개발 시 이 파일을 .env로 복사 후 값 채울 것.
# Testnet 한정 (예선 단계). 본선 시 별도 .env.production.
# =====================================================

NODE_ENV=development
PORT=3000

# ----- XRPL Testnet -----
XRPL_NETWORK_URL=wss://s.altnet.rippletest.net:51233
XRPL_EXPLORER_URL=https://testnet.xrpl.org
XRPL_FAUCET_URL=https://faucet.altnet.rippletest.net/accounts

# IOU(RLUSD 등) 계약 시 요청에서 생략하면 여기 값 사용 (issuer classic address / 3자 또는 40hex 통화)
# XRPL Testnet 공식 RLUSD 예: issuer rQhWct2fv4Vc4KRjRgMrxa8xPN9Zx9iLKV, 통화 524C555344000000000000000000000000000000
XRPL_IOU_ISSUER=
XRPL_IOU_CURRENCY=
# IOU 발행자 시드(선택). 설정 시 발행자 계정에서 직접 IOU Payment — XRPL_IOU_ISSUER 와 동일 주소여야 함.
XRPL_IOU_ISSUER_SEED=

# 내부 지갑 IOU 입금 API(/api/wallet/fund-iou) 기본 수량 (IOU value 문자열)
XRPL_WALLET_IOU_FUND_AMOUNT=1

# 운영 지갑 시드 (Testnet 전용 — Mainnet 시드와 절대 혼용 금지)
# 비워두면 부팅은 가능하나 트랜잭션 호출 시점에 실패함.
# Testnet 시드는 client.fundWallet() 등으로 발급 후 채울 것.
XRPL_OPERATOR_SEED=

# ----- PostgreSQL -----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesafe_dev

# ----- Redis (BullMQ) -----
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- PII 암호화 (AES-256-GCM) -----
# 32바이트 base64 키. 신규 생성:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 비워두면 부팅은 OK, 암호화/복호화 호출 시점에 실패함.
ENCRYPTION_MASTER_KEY=

# ----- 한전 OPM(Open P-Meter) API -----
# opm.kepco.co.kr 사업자 등록 + 활용신청(NO.8 청구정보, NO.1 일단위 전력소비) 후
# 발급받은 serviceKey 와 base URL 을 채울 것.
# 둘 다 비어있으면 호출 시점에 에러 — KEPCO_USE_MOCK=true 로 mock 우회 가능.
KEPCO_API_KEY=
KEPCO_API_BASE_URL=
# 'true' 시 KepcoMockClient 강제 사용 (NODE_ENV=test 는 별도 분기로 항상 mock)
KEPCO_USE_MOCK=false

# ----- 이메일 (월간 리포트 발송) -----
# 비워두면 부팅 OK, 첫 호출 시 에러 — EMAIL_USE_CONSOLE=true 로 console 어댑터 전환 가능.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# 'true' 시 ConsoleEmailService 강제 (NODE_ENV=test 는 별도 분기로 항상 console)
EMAIL_USE_CONSOLE=false
